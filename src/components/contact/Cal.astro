<!-- Cal inline embed code begins -->
<div style="width:100%;height:570px;overflow:scroll" id="my-cal-inline"></div>
<script is:inline>
  (function () {
    function initCal() {
      var container = document.getElementById("my-cal-inline");
      if (!container) return;

      window.Cal = undefined;
      var scripts = document.querySelectorAll(
        'script[src*="cal.com/embed/embed.js"]'
      );
      for (var i = 0; i < scripts.length; i++) {
        scripts[i].remove();
      }

      (function (C, A, L) {
        var p = function (a, ar) {
          a.q.push(ar);
        };
        var d = C.document;
        C.Cal =
          C.Cal ||
          function () {
            var cal = C.Cal;
            var ar = arguments;
            if (!cal.loaded) {
              cal.ns = {};
              cal.q = cal.q || [];
              d.head.appendChild(d.createElement("script")).src = A;
              cal.loaded = true;
            }
            if (ar[0] === L) {
              var api = function () {
                p(api, arguments);
              };
              var namespace = ar[1];
              api.q = api.q || [];
              if (typeof namespace === "string") {
                cal.ns[namespace] = cal.ns[namespace] || api;
                p(cal.ns[namespace], ar);
                p(cal, ["initNamespace", namespace]);
              } else p(cal, ar);
              return;
            }
            p(cal, ar);
          };
      })(window, "https://app.cal.com/embed/embed.js", "init");
      Cal("init", "15min", { origin: "https://cal.com" });
      Cal.ns["15min"]("inline", {
        elementOrSelector: "#my-cal-inline",
        config: { layout: "month_view", theme: "light" },
        calLink: "jst-kishan/15min",
      });
      Cal.ns["15min"]("ui", {
        theme: "light",
        styles: { branding: { brandColor: "#000000" } },
        hideEventTypeDetails: false,
        layout: "month_view",
      });
    }

    document.addEventListener("astro:page-load", initCal);
  })();
</script>
<!-- Cal inline embed code ends -->
