---

import gitaGPTBanner from '@/assets/gita-gpt.png'
import heyStatusBanner from '@/assets/hey-status-2.png'
import jumsBanner from '@/assets/jumsbanner.webp'
import myPRsBanner from '@/assets/myprs-banner.png'
import snapsearchBanner from '@/assets/snapsearch.png'
import strollBanner from '@/assets/stroll.webp'
import suniyeBanner from '@/assets/suniye-banner.png'
import ProjectCard from './ProjectCard.astro'

const projects = [
  {
    title: 'Suniye',
    subtitle: '500+ Downloads',
    description:
      'Open-source, local-first dictation for macOS. Speech recognition runs on-device with Apple Speech and offline ASR models, so your audio never leaves your Mac.',
    image: suniyeBanner,
    link: 'https://suniye.kishans.in',
  },
  {
    title: 'Gita GPT',
    subtitle: '13M+ Views | 120K+ Users',
    description:
      'An AI advisor based on the Bhagavad Gita that answers life questions through the lens of Shree Krishna.',
    image: gitaGPTBanner,
    link: 'https://gita.kishans.in',
  },
  {
    title: 'MyPRs',
    description: 'One link to highlight your Open-Source Contributions.',
    image: myPRsBanner,
    link: 'https://myprs.dev',
  },
  {
    title: 'JUMS Reboot',
    subtitle: '1,000+ Downloads | 5.0 Rating',
    description:
      'A utility app for Jadavpur University students to access admit cards, grade cards, and exam schedules.',
    image: jumsBanner,
    link: 'https://play.google.com/store/apps/details?id=com.kishans.jumsRebootFlutter&hl=en_IN',
  },
  {
    title: 'HeyStatus',
    description: 'A real-time status page for your services.',
    image: heyStatusBanner,
    link: 'https://hey-status.pages.dev',
  },
  {
    title: 'SnapSearch',
    subtitle: '242+ Users',
    description: 'Search the web distraction-free',
    image: snapsearchBanner,
    link: 'https://chromewebstore.google.com/detail/snapsearch-better-search/aeblbpjamlpjfedjbkhnbiecmepbgkdo',
  },
  // {
  //   title: 'Stroll',
  //   description:
  //     'Stroll is a browser extension that automatically scrolls your browser to the accepted answer on Stack-Overflow.',
  //   image: strollBanner,
  //   link: 'https://stroll-land.vercel.app',
  // },
]
---

<div class="my-8 sm:my-10" id="projects">
  <div class="container" id="projects-header">
    <h3 class="text-xl sm:text-2xl font-semibold">Personal Projects</h3>
    <h4 class="text-lg sm:text-xl text-foreground/70 mt-3 sm:mt-4">
      Building things is my therapy.
    </h4>
  </div>
  <div
    class="grid grid-cols-1 sm:grid-cols-2 gap-2 max-w-6xl mx-auto mt-8 sm:mt-16"
    id="projects-grid"
  >
    {projects.map((project) => <ProjectCard {...project} />)}
  </div>
</div>
