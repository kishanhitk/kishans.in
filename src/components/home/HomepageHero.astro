---

import { MoveRight } from 'lucide-react'
import { Button } from '@/components/ui/button'
---

<div class="container">
  <h1
    class="enter text-3xl sm:text-4xl font-bold text-foreground"
    style="--enter-index: 0"
  >
    Hello, I'm Kishan.
  </h1>
  <h2
    class="enter text-xl sm:text-2xl text-muted-foreground mt-2"
    style="--enter-index: 1"
  >
    A product engineer building AI agent systems.
  </h2>
  <p
    class="enter text-lg sm:text-xl mt-4 sm:mt-5 text-foreground/80"
    style="--enter-index: 2"
  >
    I like building useful products end-to-end, from agent workflows and
    evaluation systems to native apps and web products. These days, I work at
    Plivo on tools that help teams build, test, and improve AI agents, including
    voice agents, before they reach production.
  </p>
  <a
    href="/about"
    class="enter inline-block mt-6 sm:mt-8"
    style="--enter-index: 3"
  >
    <Button
      className="px-6 sm:px-8 rounded-full py-4 sm:py-5 font-mono text-sm sm:text-base group"
    >
      More About Me
      <MoveRight
        strokeWidth={1.2}
        className="ml-2 transition-transform duration-200 ease-[var(--ease-out)] group-hover:translate-x-1"
      />
    </Button>
  </a>
</div>
