---

import { Image } from 'astro:assets'

interface Props {
  title: string
  subtitle?: string
  description: string
  image: ImageMetadata
  link: string
}

const { title, subtitle, description, image, link } = Astro.props
---

<a
  href={link}
  data-reveal
  class="rounded-xl overflow-hidden p-6 sm:p-10 bg-secondary dark:bg-white/[0.03] m-4 group"
  target="_blank"
  rel="noreferrer"
>
  <Image
    src={image}
    alt={title}
    width={600}
    height={400}
    class="rounded-xl w-full shadow-lg object-cover transition-transform duration-300 ease-[var(--ease-out)] group-hover:scale-[1.03] motion-reduce:transition-none motion-reduce:group-hover:scale-100"
  />
  <div class="mt-4">
    <h5 class="text-lg sm:text-xl font-semibold">
      {title}
      <span class="text-sm text-foreground/60 ml-2">{subtitle}</span>
    </h5>
    <p class="text-sm sm:text-base text-foreground/70 mt-1">
      {description}
    </p>
  </div>
</a>
