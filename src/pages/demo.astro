---
// Utility page used only to generate the OG banner (og-banner.png) — screenshot
// this route at 1200x630. Renders the card as the full page (no Layout header)
// so the capture is clean.
import '@/styles/global.css'
import RetroGrid from '@/components/ui/retro-grid'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex, nofollow" />
    <title>OG image generator</title>
    <style>
      html,
      body {
        margin: 0;
      }
    </style>
  </head>
  <body>
    <div
      class="relative flex h-[630px] w-[1200px] flex-col items-center justify-center overflow-hidden bg-white"
    >
      <RetroGrid />
      <div class="z-10 flex flex-col items-center">
        <h1 class="text-[9.3rem] font-bold text-black">
          Kishan <span class="text-black/70">Kumar</span>
        </h1>
        <div class="mt-1 space-y-3 text-center text-4xl text-gray-600">
          <div>Product Engineer</div>
          <div>AI Agents &amp; Voice AI</div>
          <div>Simulation &amp; Evaluation</div>
        </div>
      </div>
    </div>
  </body>
</html>
