---

import Writing from '@/components/home/WritingItem.astro'
import { Separator } from '@/components/ui/separator'
import { getAllPostByUsername } from '@/functions/hashnode'
import Layout from '@/layouts/Layout.astro'
import type { HashnodePost } from '@/types'

const posts = await getAllPostByUsername('blog.kishans.in')
const description =
  'Writing by Kishan Kumar on AI agents, developer tools, product engineering, native apps, and building reliable software.'
---

<Layout title="Writing on AI Agents, Developer Tools & Product Engineering | Kishan Kumar" {description}>
  <div class="container mb-12 sm:mb-20 min-h-screen">
    <h1 class="text-3xl sm:text-4xl font-bold text-foreground">
      Recent Writings
    </h1>

    <div class="mt-4 sm:mt-6">
      {
        posts?.map((post: HashnodePost, index) => {
          return (
            <>
              <Writing post={post} />
              {index !== posts.length - 1 && (
                <Separator className="my-5 sm:my-7" />
              )}
            </>
          );
        })
      }
    </div>
  </div>
</Layout>
